<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Planes - Admin - DocVeh</title>
  <link rel="stylesheet" href="/css/style.css">
  <%- customCSS %>
  <style>
    .settings-form { max-width: 800px; }
    .settings-form .form-group textarea { width: 100%; padding: 12px 15px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.95rem; font-family: inherit; resize: vertical; min-height: 60px; outline: none; }
    .settings-form .form-group textarea:focus { border-color: var(--cyan); }
    .settings-form .form-group input { font-size: 0.95rem; }
    .settings-group { background: #f8f9fa; border-radius: 8px; padding: 15px; margin-bottom: 15px; }
    .settings-group h4 { color: var(--navy); margin-bottom: 10px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.5px; }
  </style>
</head>
<body>
  <nav class="navbar admin-navbar">
    <div class="container">
      <a href="/admin" class="logo"><img src="/logo.png" alt="DocVeh" style="height:120px;vertical-align:middle;"> <span class="admin-badge" style="font-size:0.7rem;background:var(--admin-badge-bg);color:var(--admin-badge-text);padding:2px 8px;border-radius:4px;vertical-align:middle;">ADMIN</span></a>
      <nav>
        <span class="user-name"><%= userName %></span>
        <a href="/profile">Mi Perfil</a>
        <a href="/subscriptions"><%= planName || 'Plan Gratuito' %></a>
        <div class="dropdown">
          <a>Admin ▾</a>
          <div class="dropdown-content">
            <a href="/admin">Panel</a>
            <a href="/admin/users">Usuarios</a>
            <a href="/admin/payments">Pagos</a>
            <a href="/admin/plans">Planes</a>
            <a href="/admin/logs">Registros</a>
            <a href="/admin/backups">Backups</a>
            <a href="/admin/settings">Configuración</a>
            <a href="/admin/colors">Colores</a>
          </div>
        </div>
        <a href="/activity-log">📋 Actividad</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/new-vehicle">+ Añadir Vehículo</a>
        <a href="/logout">Cerrar Sesión</a>
      </nav>
    </div>
  </nav>

  <div class="container">
    <div class="dashboard-header">
      <h1>Planes y Suscripciones</h1>
      <a href="/admin" class="btn btn-secondary">← Volver al Panel</a>
    </div>

    <% if (msg) { %><div class="alert" style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;"><%= msg %></div><% } %>

    <form method="POST" action="/admin/plans" class="settings-form">
      <div class="card">
        <h3>Editar Planes</h3>
        <div class="settings-group">
          <div class="form-group">
            <label>Título de la sección de planes</label>
            <input type="text" name="plans_title" value="<%= settings.plans_title %>">
          </div>
        </div>
        <% availablePlans.forEach(function(plan) { %>
          <div class="settings-group">
            <h4><%= plan.name %> (<%= plan.price === 0 ? 'Gratis' : '$' + plan.price.toLocaleString('es-CL') %>)</h4>
            <input type="hidden" name="plan_<%= plan.id %>_id" value="<%= plan.id %>">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div class="form-group">
                <label>Nombre</label>
                <input type="text" name="plan_<%= plan.id %>_name" value="<%= plan.name %>">
              </div>
              <div class="form-group">
                <label>Descripción</label>
                <input type="text" name="plan_<%= plan.id %>_description" value="<%= plan.description %>">
              </div>
              <div class="form-group">
                <label>Precio (CLP$)</label>
                <input type="number" step="1" name="plan_<%= plan.id %>_price" value="<%= plan.price %>">
              </div>
              <div class="form-group">
                <label>Máx. vehículos</label>
                <input type="number" name="plan_<%= plan.id %>_max_vehicles" value="<%= plan.max_vehicles %>">
              </div>
              <div class="form-group">
                <label>Máx. documentos</label>
                <input type="number" name="plan_<%= plan.id %>_max_documents" value="<%= plan.max_documents %>">
              </div>
              <div class="form-group">
                <label>Máx. enlaces NFC</label>
                <input type="number" name="plan_<%= plan.id %>_max_nfc_links" value="<%= plan.max_nfc_links %>">
              </div>
              <div class="form-group">
                <label>Máx. tamaño archivo (MB)</label>
                <input type="number" name="plan_<%= plan.id %>_max_file_size" value="<%= plan.max_file_size %>">
              </div>
              <div class="form-group" style="display:flex;align-items:center;gap:10px;padding-top:20px;">
                <label>Protección PIN</label>
                <input type="checkbox" name="plan_<%= plan.id %>_has_pin_protection" value="1" <%= plan.has_pin_protection ? 'checked' : '' %> style="width:20px;height:20px;cursor:pointer;">
              </div>
              <div class="form-group" style="display:flex;align-items:center;gap:10px;padding-top:20px;">
                <label>Enlaces NFC</label>
                <input type="checkbox" name="plan_<%= plan.id %>_has_nfc" value="1" <%= plan.has_nfc ? 'checked' : '' %> style="width:20px;height:20px;cursor:pointer;">
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:1.1rem;margin-bottom:30px;">Guardar Planes</button>
    </form>
  </div>
</body>
</html>
