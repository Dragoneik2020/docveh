<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuarios - Admin - DocVeh</title>
  <link rel="stylesheet" href="/css/style.css">
  <%- customCSS %>
  <style>
    .search-box { width:100%;padding:12px 15px;border:2px solid #e0e0e0;border-radius:8px;font-size:1rem;margin-bottom:20px; }
    .search-box:focus { border-color:#4cc9f0;outline:none; }
    .badge-admin { background:#e74c3c;color:#fff;padding:3px 12px;border-radius:50px;font-size:0.8rem;font-weight:600; }
    .badge-user { background:#4cc9f0;color:#fff;padding:3px 12px;border-radius:50px;font-size:0.8rem;font-weight:600; }
    .badge-plan { background:#e8f4fd;color:#2196f3;padding:3px 10px;border-radius:50px;font-size:0.8rem;font-weight:600; }
    .badge-manual { background:#fff3e0;color:#e67e22;padding:3px 10px;border-radius:50px;font-size:0.7rem;font-weight:600;border:1px solid #ffd54f; }
    .badge-purchased { background:#e8f5e9;color:#2e7d32;padding:3px 10px;border-radius:50px;font-size:0.7rem;font-weight:600;border:1px solid #a5d6a7; }
  </style>
</head>
<body>
  <nav class="navbar admin-navbar">
    <div class="container">
      <a href="/admin" class="logo"><img src="/logo.png" alt="DocVeh" style="height:120px;vertical-align:middle;"> <span class="admin-badge" style="font-size:0.7rem;background:var(--admin-badge-bg);color:var(--admin-badge-text);padding:2px 8px;border-radius:4px;vertical-align:middle;">ADMIN</span></a>
      <nav>
        <span class="user-name"><%= userName %></span>
        <a href="/profile">Mi Perfil</a>
        <a href="/subscriptions"><%= planName || 'Plan Gratuito' %></a>
        <div class="dropdown">
          <a>Admin ▾</a>
          <div class="dropdown-content">
            <a href="/admin">Panel</a>
            <a href="/admin/users">Usuarios</a>
            <a href="/admin/payments">Pagos</a>
            <a href="/admin/plans">Planes</a>
            <a href="/admin/logs">Registros</a>
            <a href="/admin/backups">Backups</a>
            <a href="/admin/settings">Configuración</a>
            <a href="/admin/notifications">Notificaciones</a>
            <a href="/admin/colors">Colores</a>
          </div>
        </div>
        <a href="/activity-log">📋 Actividad</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/new-vehicle">+ Añadir Vehículo</a>
        <a href="/logout">Cerrar Sesión</a>
      </nav>
    </div>
  </nav>

  <div class="container">
<div class="dashboard-header">
      <h1>GestiA3n de Usuarios</h1>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <a href="/admin/user/new" class="btn btn-primary">+ Crear Usuario</a>
        <a href="/admin" class="btn btn-secondary">← Volver al Panel</a>
      </div>
    </div>

    <input type="text" class="search-box" id="searchInput" placeholder="Buscar por nombre, email o ID..." onkeyup="filterUsers()">

    <div class="card" style="padding:0;overflow-x:auto;">
      <table class="admin-table" id="usersTable">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Plan</th>
            <th>Origen Plan</th>
            <th>Registro</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr class="user-row" data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-id="<%= u.id %>">
              <td style="color:#888;"><%= u.id %></td>
              <td style="font-weight:600;"><%= u.name %></td>
              <td><%= u.email %></td>
              <td><span class="<%= u.role === 'admin' ? 'badge-admin' : 'badge-user' %>"><%= u.role %></span></td>
              <td><span class="badge-plan"><%= u.plan_name || 'Gratuito' %></span></td>
              <td>
                <% if (u.plan_price && u.plan_price > 0) { %>
                  <% if (u.sub_source === 'manual') { %>
                    <span class="badge-manual">✏️ Manual</span>
                  <% } else { %>
                    <span class="badge-purchased">🛒 Comprado</span>
                  <% } %>
                <% } else { %>
                  <span style="color:#888;">—</span>
                <% } %>
              </td>
              <td style="color:#888;font-size:0.85rem;"><%= u.created_at %></td>
              <td style="display:flex;gap:8px;flex-wrap:wrap;">
                <a href="/admin/user/<%= u.id %>/edit" class="btn btn-primary btn-small">Editar</a>
                <form method="POST" action="/admin/user/<%= u.id %>/toggle-role" style="display:inline;">
                  <button type="submit" class="btn btn-warning btn-small">
                    <%= u.role === 'admin' ? 'Quitar Admin' : 'Hacer Admin' %>
                  </button>
                </form>
                <% if (parseInt(u.id) !== parseInt(currentUserId)) { %>
                  <form method="POST" action="/admin/user/<%= u.id %>/delete" style="display:inline;" onsubmit="return confirm('¿Eliminar este usuario y todos sus datos? Vehículos, documentos, NFC y archivos se perderán permanentemente.')">
                    <button type="submit" class="btn btn-danger btn-small">Eliminar</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div id="noResults" class="empty-state" style="display:none;">
      <div class="empty-icon">🔍</div>
      <h3>Sin resultados</h3>
      <p>No se encontraron usuarios con ese criterio de búsqueda.</p>
    </div>
  </div>

  <script>
    function filterUsers() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      const rows = document.querySelectorAll('.user-row');
      let visible = 0;
      rows.forEach(r => {
        const match = r.dataset.name.includes(q) || r.dataset.email.includes(q) || r.dataset.id === q;
        r.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    }
  </script>
</body>
</html>
